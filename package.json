{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "bash ./scripts/dev.sh",
    "build": "astro build",
    "preview": "astro preview",
    "lint": "eslint .",
    "typecheck": "astro check",
    "format": "prettier --write .",
    "validate": "npm run lint && npm run typecheck && npm run build",
    "qa": "bash ./scripts/qa.sh",
    "test:e2e": "playwright test",
    "lighthouse": "bash ./scripts/lighthouse.sh",
    "new:project": "bash ./scripts/new-project.sh"
  },
  "dependencies": {
    "astro": "^6.3.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.3.1",
    "globals": "^16.5.0",
    "postcss": "^8.5.15",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2"
  },
  "overrides": {
    "yaml-language-server": {
      "yaml": "2.9.0"
    }
  }
}
