---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Senad | DevOps Portfolio',
  description = 'Single-page DevOps portfolio built with Astro and Tailwind.',
  ogImage = '/og-image.svg',
} = Astro.props;

const pageBaseUrl = Astro.site ?? Astro.url;
const canonicalUrl = new URL(Astro.url.pathname, pageBaseUrl).toString();
const resolvedOgImage = new URL(ogImage, pageBaseUrl).toString();

const navLinks = [
  { href: '#home', label: 'Home' },
  { href: '#projects', label: 'Projects' },
  { href: '#experience', label: 'Experience' },
  { href: '#skills', label: 'Skills' },
  { href: '#certifications', label: 'Certifications' },
  { href: '#about', label: 'About' },
  { href: '#contact', label: 'Contact' },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link
      rel="icon"
      type="image/svg+xml"
      href={`${import.meta.env.BASE_URL}favicon.svg`}
    />
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />
    <meta name="theme-color" content="#050816" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={resolvedOgImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />

    <title>{title}</title>
  </head>
  <body class="page-shell">
    <a href="#main-content" class="skip-link focus-ring">Skip to content</a>

    <header class="site-header" data-site-header>
      <nav class="site-nav" aria-label="Primary navigation">
        <a href="#home" class="brand-link focus-ring">Senad Dizdarevic</a>

        <button
          type="button"
          class="nav-toggle focus-ring"
          data-nav-toggle
          aria-expanded="false"
          aria-controls="primary-nav-links"
          aria-label="Open navigation menu"
        >
          <span class="sr-only">Toggle navigation menu</span>
          <span class="nav-toggle-icon" aria-hidden="true">
            <span class="nav-toggle-line"></span>
            <span class="nav-toggle-line"></span>
            <span class="nav-toggle-line"></span>
          </span>
        </button>

        <ul id="primary-nav-links" class="nav-links" role="list" data-nav-list>
          {
            navLinks.map((link, index) => (
              <li>
                <a
                  href={link.href}
                  data-nav-link
                  aria-current={index === 0 ? 'true' : undefined}
                  class:list={[
                    'nav-link',
                    'focus-ring',
                    index === 0 && 'is-active',
                  ]}
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </header>

    <canvas class="signal-canvas" aria-hidden="true" data-signal-canvas></canvas>

    <main id="main-content" class="site-main">
      <slot />
    </main>

    <script>
      (() => {
        const header = document.querySelector('[data-site-header]');
        const navToggle = document.querySelector('[data-nav-toggle]');
        const navList = document.querySelector('[data-nav-list]');
        const desktopMediaQuery = window.matchMedia('(min-width: 768px)');

        const headerElement = header instanceof HTMLElement ? header : null;
        const navToggleButton =
          navToggle instanceof HTMLButtonElement ? navToggle : null;

        const navLinks = Array.from(
          document.querySelectorAll('[data-nav-link]'),
        ).filter(
          (link): link is HTMLAnchorElement =>
            link instanceof HTMLAnchorElement,
        );

        // ── Canvas-based signal animation ─────────────────────────────────────
        const signalCanvas = document.querySelector('[data-signal-canvas]');
        const signalCtx =
          signalCanvas instanceof HTMLCanvasElement
            ? signalCanvas.getContext('2d')
            : null;

        const GRID_SIZE = 48;
        const GRID_OFFSET = 0.5;
        const EDGE_BUFFER = 28;
        const MIN_DOT_DISTANCE = GRID_SIZE * 2.0;

        type Direction  = 'up' | 'down' | 'left' | 'right';
        type SignalColor = 'cyan' | 'violet' | 'amber';
        type SignalSize  = 'sm' | 'md' | 'lg';

        interface SignalDot {
          x: number;
          y: number;
          direction: Direction;
          speed: number;
          turnChance: number;
          color: SignalColor;
          size: SignalSize;
          baseOpacity: number;
          opacityPhase: number;
          opacitySpeed: number;
          opacity: number;
          trail: Array<{ x: number; y: number }>;
        }

        const SIGNAL_RGB: Record<SignalColor, readonly [number, number, number]> = {
          cyan:   [34,  211, 238],
          violet: [139, 92,  246],
          amber:  [251, 146, 60 ],
        };

        // Trail point recorded every TRAIL_STEP px of movement (sparsification).
        // Reduces stored points ~4× vs one-per-frame, cutting draw calls proportionally.
        const TRAIL_STEP    = 2;               // px between recorded trail points
        const TRAIL_STEP_SQ = TRAIL_STEP * TRAIL_STEP;

        // maxPts = visual trail length / TRAIL_STEP
        const TRAIL_CFG: Record<
          SignalSize,
          { maxPts: number; maxPtsLite: number; width: number; headSize: number; headGlow: number }
        > = {
          sm: { maxPts:  8, maxPtsLite:  4, width: 1.4, headSize: 3.0, headGlow:  7 },
          md: { maxPts: 14, maxPtsLite:  7, width: 2.4, headSize: 5.5, headGlow: 12 },
          lg: { maxPts: 21, maxPtsLite: 10, width: 3.4, headSize: 8.0, headGlow: 17 },
        };

        // Pre-cached solid colour strings — avoids rgba() string building in the hot path.
        const SIGNAL_RGB_STR: Record<SignalColor, string> = {
          cyan:   'rgb(34,211,238)',
          violet: 'rgb(139,92,246)',
          amber:  'rgb(251,146,60)',
        };

        // Buckets reduce draw calls from ~N (one per point) to a fixed small number.
        const TRAIL_BUCKETS_FULL = 6;  // desktop: smooth fade in 6 paths
        const TRAIL_BUCKETS_LITE = 3;  // mobile:  3 paths, imperceptibly coarser

        const randomInRange = (min: number, max: number) =>
          Math.random() * (max - min) + min;

        const randomGridCoordinate = (max: number) => {
          const lineCount = Math.max(1, Math.floor(max / GRID_SIZE));
          return Math.round(randomInRange(0, lineCount)) * GRID_SIZE + GRID_OFFSET;
        };

        const turnLeft = (d: Direction): Direction => {
          if (d === 'right') return 'up';
          if (d === 'up')    return 'left';
          if (d === 'left')  return 'down';
          return 'right';
        };

        const turnRight = (d: Direction): Direction => {
          if (d === 'right') return 'down';
          if (d === 'down')  return 'left';
          if (d === 'left')  return 'up';
          return 'right';
        };

        const reverseDirection = (d: Direction): Direction => {
          if (d === 'right') return 'left';
          if (d === 'left')  return 'right';
          if (d === 'up')    return 'down';
          return 'up';
        };

        const moveDot = (dot: SignalDot, distance: number) => {
          if (dot.direction === 'right') { dot.x += distance; return; }
          if (dot.direction === 'left')  { dot.x -= distance; return; }
          if (dot.direction === 'down')  { dot.y += distance; return; }
          dot.y -= distance;
        };

        const distanceToIntersection = (dot: SignalDot) => {
          const axis = (dot.direction === 'left' || dot.direction === 'right')
            ? dot.x : dot.y;
          const mod = ((( axis - GRID_OFFSET) % GRID_SIZE) + GRID_SIZE) % GRID_SIZE;
          if (dot.direction === 'right' || dot.direction === 'down') {
            return mod < 0.001 ? GRID_SIZE : GRID_SIZE - mod;
          }
          return mod < 0.001 ? GRID_SIZE : mod;
        };

        let sceneWidth  = window.innerWidth;
        let sceneHeight = window.innerHeight;
        let worldHeight = Math.max(window.innerHeight, document.documentElement.scrollHeight);
        let sceneDpr    = window.devicePixelRatio || 1;

        const resizeSignalCanvas = () => {
          if (!(signalCanvas instanceof HTMLCanvasElement) || !signalCtx) return;
          sceneWidth  = window.innerWidth;
          sceneHeight = window.innerHeight;
          worldHeight = Math.max(sceneHeight, document.documentElement.scrollHeight);
          sceneDpr = Math.min(window.devicePixelRatio || 1, isLiteMode ? 1.5 : 2);
          signalCanvas.width  = sceneWidth  * sceneDpr;
          signalCanvas.height = sceneHeight * sceneDpr;
          signalCanvas.style.width  = `${sceneWidth}px`;
          signalCanvas.style.height = `${sceneHeight}px`;
          signalCtx.setTransform(sceneDpr, 0, 0, sceneDpr, 0, 0);
        };

        const chooseDirection = (dot: SignalDot) => {
          const forceTurn =
            (dot.direction === 'left'  && dot.x <= GRID_SIZE + GRID_OFFSET) ||
            (dot.direction === 'right' && dot.x >= sceneWidth  - GRID_SIZE + GRID_OFFSET) ||
            (dot.direction === 'up'    && dot.y <= GRID_SIZE + GRID_OFFSET) ||
            (dot.direction === 'down'  && dot.y >= worldHeight - GRID_SIZE + GRID_OFFSET);

          if (forceTurn || Math.random() < dot.turnChance) {
            dot.direction = Math.random() < 0.5
              ? turnLeft(dot.direction)
              : turnRight(dot.direction);
            return;
          }
          if (Math.random() < 0.02) {
            dot.direction = reverseDirection(dot.direction);
          }
        };

        const wrapDot = (dot: SignalDot) => {
          const outX = dot.x < -EDGE_BUFFER || dot.x > sceneWidth  + EDGE_BUFFER;
          const outY = dot.y < -EDGE_BUFFER || dot.y > worldHeight + EDGE_BUFFER;
          if (outX || outY) {
            dot.trail.length = 0;
            if (dot.x < -EDGE_BUFFER)                   dot.x = sceneWidth  + EDGE_BUFFER;
            else if (dot.x > sceneWidth  + EDGE_BUFFER)  dot.x = -EDGE_BUFFER;
            if (dot.y < -EDGE_BUFFER)                    dot.y = worldHeight + EDGE_BUFFER;
            else if (dot.y > worldHeight + EDGE_BUFFER)  dot.y = -EDGE_BUFFER;
          }
        };

        const updateDot = (dot: SignalDot, deltaSeconds: number) => {
          let remaining = dot.speed * deltaSeconds;
          while (remaining > 0) {
            const step   = distanceToIntersection(dot);
            const travel = Math.min(remaining, step);
            moveDot(dot, travel);
            remaining -= travel;
            if (travel + 0.001 >= step) {
              dot.x = Math.round((dot.x - GRID_OFFSET) / GRID_SIZE) * GRID_SIZE + GRID_OFFSET;
              dot.y = Math.round((dot.y - GRID_OFFSET) / GRID_SIZE) * GRID_SIZE + GRID_OFFSET;
              chooseDirection(dot);
            }
          }
          wrapDot(dot);
        };

        // Record the current position only when the dot has moved >= TRAIL_STEP px
        // from the last recorded point (sparsification).  Trim by max point count
        // using shift() — no per-frame array allocation unlike the old slice() approach.
        const updateTrail = (dot: SignalDot) => {
          const trail = dot.trail;
          if (trail.length > 0) {
            const last = trail[trail.length - 1];
            const dx = dot.x - last.x;
            const dy = dot.y - last.y;
            if (dx * dx + dy * dy < TRAIL_STEP_SQ) return; // not far enough yet
          }
          trail.push({ x: dot.x, y: dot.y });
          const maxPts = isLiteMode
            ? TRAIL_CFG[dot.size].maxPtsLite
            : TRAIL_CFG[dot.size].maxPts;
          if (trail.length > maxPts) trail.shift();
        };

        const updateOpacity = (dot: SignalDot, deltaSeconds: number) => {
          dot.opacityPhase += dot.opacitySpeed * deltaSeconds;
          if (dot.opacityPhase > Math.PI * 2) dot.opacityPhase -= Math.PI * 2;
          const minOp = dot.baseOpacity * 0.28;
          dot.opacity =
            minOp + (dot.baseOpacity - minOp) * (0.5 + 0.5 * Math.sin(dot.opacityPhase));
        };

        // Unified bucketed trail renderer — draws the trail as a small fixed number
        // of batched paths (TRAIL_BUCKETS_FULL on desktop, TRAIL_BUCKETS_LITE on mobile)
        // instead of one stroke() per point.  Uses globalAlpha so strokeStyle is set
        // once per dot (no per-segment string allocation).
        const drawTrail = (dot: SignalDot) => {
          const { trail, opacity, size } = dot;
          if (trail.length < 2 || !signalCtx) return;
          const n       = trail.length;
          const cfg     = TRAIL_CFG[size];
          const buckets = isLiteMode ? TRAIL_BUCKETS_LITE : TRAIL_BUCKETS_FULL;

          signalCtx.lineCap    = 'round';
          signalCtx.lineJoin   = 'round';
          signalCtx.strokeStyle = SIGNAL_RGB_STR[dot.color]; // set once per dot

          for (let bucket = 0; bucket < buckets; bucket++) {
            const si = Math.floor((bucket       / buckets) * (n - 1));
            const ei = Math.floor(((bucket + 1) / buckets) * (n - 1));
            if (ei <= si) continue;
            const t = (bucket + 1) / buckets;
            signalCtx.globalAlpha = t * t * opacity * 0.88; // quadratic fade
            signalCtx.lineWidth   = cfg.width * (0.18 + 0.82 * t);
            signalCtx.beginPath();
            signalCtx.moveTo(trail[si].x, trail[si].y);
            for (let i = si + 1; i <= ei; i++) {
              signalCtx.lineTo(trail[i].x, trail[i].y);
            }
            signalCtx.stroke();
          }
          signalCtx.globalAlpha = 1; // reset for head drawing
        };

        const drawSignal = (dot: SignalDot) => {
          if (!signalCtx) return;
          const [r, g, b] = SIGNAL_RGB[dot.color];
          const cfg = TRAIL_CFG[dot.size];
          const { opacity } = dot;

          drawTrail(dot); // resets globalAlpha to 1

          // Outer glow (skip on lite mode)
          if (!isLiteMode) {
            const glowR    = cfg.headGlow * 2.0;
            const outerGrd = signalCtx.createRadialGradient(
              dot.x, dot.y, 0, dot.x, dot.y, glowR,
            );
            outerGrd.addColorStop(0, `rgba(${r},${g},${b},${(opacity * 0.30).toFixed(3)})`);
            outerGrd.addColorStop(1, 'rgba(0,0,0,0)');
            signalCtx.fillStyle = outerGrd;
            signalCtx.beginPath();
            signalCtx.arc(dot.x, dot.y, glowR, 0, Math.PI * 2);
            signalCtx.fill();
          }

          // Bright core with radial gradient (white centre → colour → transparent)
          const coreR   = cfg.headSize * 1.4;
          const coreGrd = signalCtx.createRadialGradient(
            dot.x, dot.y, 0, dot.x, dot.y, coreR,
          );
          coreGrd.addColorStop(0,    `rgba(255,255,255,${(opacity * 0.96).toFixed(3)})`);
          coreGrd.addColorStop(0.38, `rgba(${r},${g},${b},${(opacity * 0.85).toFixed(3)})`);
          coreGrd.addColorStop(1,    'rgba(0,0,0,0)');
          signalCtx.fillStyle = coreGrd;
          signalCtx.beginPath();
          signalCtx.arc(dot.x, dot.y, coreR, 0, Math.PI * 2);
          signalCtx.fill();
        };

        const createSignalDot = (existingDots: SignalDot[]): SignalDot => {
          const createStartState = () => {
            const horizontalStart = Math.random() < 0.5;
            const x = horizontalStart
              ? randomInRange(-EDGE_BUFFER, sceneWidth + EDGE_BUFFER)
              : randomGridCoordinate(sceneWidth);
            const y = horizontalStart
              ? randomGridCoordinate(worldHeight)
              : randomInRange(-EDGE_BUFFER, worldHeight + EDGE_BUFFER);
            const direction: Direction = horizontalStart
              ? (Math.random() < 0.5 ? 'left' : 'right')
              : (Math.random() < 0.5 ? 'up'   : 'down');
            return { x, y, direction };
          };

          let startState = createStartState();
          for (let attempt = 0; attempt < 90; attempt += 1) {
            const candidate = createStartState();
            const tooClose = existingDots.some(
              (d) => Math.hypot(candidate.x - d.x, candidate.y - d.y) < MIN_DOT_DISTANCE,
            );
            if (!tooClose) { startState = candidate; break; }
          }

          const colorRoll = Math.random();
          const color: SignalColor =
            colorRoll < 0.30 ? 'violet' : colorRoll < 0.44 ? 'amber' : 'cyan';

          const sizeRoll = Math.random();
          const size: SignalSize =
            sizeRoll < 0.15 ? 'lg' : sizeRoll < 0.30 ? 'sm' : 'md';

          const baseOpacity = randomInRange(0.52, 0.88);

          return {
            x: startState.x,
            y: startState.y,
            direction: startState.direction,
            speed:        randomInRange(18, 42),
            turnChance:   randomInRange(0.3, 0.52),
            color,
            size,
            baseOpacity,
            opacityPhase: randomInRange(0, Math.PI * 2),
            opacitySpeed: randomInRange(0.3, 0.8),
            opacity:      baseOpacity,
            trail:        [],
          };
        };

        let signalDots: SignalDot[]  = [];
        let signalFrameId            = 0;
        let signalLastFrame          = 0;
        let signalResizeTimer        = 0;
        let isLiteMode               = false; // set in rebuildSignals
        let liteFrameInterval        = 0;     // ms; 0 = uncapped (desktop)

        const getSeparationFactor = (dot: SignalDot) => {
          // O(N²) — only used during dot creation for initial placement spacing;
          // removed from the per-frame animation loop.
          let factor = 1;
          const t1sq = (GRID_SIZE * 0.95) * (GRID_SIZE * 0.95);
          const t2sq = (GRID_SIZE * 1.50) * (GRID_SIZE * 1.50);
          for (const other of signalDots) {
            if (other === dot) continue;
            const dx = dot.x - other.x;
            const dy = dot.y - other.y;
            const dSq = dx * dx + dy * dy;
            if (dSq < t1sq) { factor = Math.min(factor, 0.3); break; }
            else if (dSq < t2sq) factor = Math.min(factor, 0.68);
          }
          return factor;
        };
        void getSeparationFactor; // kept for potential future use

        const animateSignals = (timestamp: number) => {
          if (!signalCtx) return;
          // Lite mode: cap at 30 fps — skip frame if too soon
          if (liteFrameInterval > 0 && timestamp - signalLastFrame < liteFrameInterval - 1) {
            signalFrameId = window.requestAnimationFrame(animateSignals);
            return;
          }
          const deltaSeconds = Math.min(
            0.05,
            Math.max(0.001, (timestamp - signalLastFrame) / 1000),
          );
          signalLastFrame = timestamp;

          const scrollY = window.scrollY;
          signalCtx.clearRect(0, 0, sceneWidth, sceneHeight);
          signalCtx.save();
          signalCtx.translate(0, -scrollY); // world → screen coords

          for (const dot of signalDots) {
            updateDot(dot, deltaSeconds);
            updateOpacity(dot, deltaSeconds);
            updateTrail(dot);
            if (dot.y < scrollY - 60 || dot.y > scrollY + sceneHeight + 60) continue;
            drawSignal(dot);
          }

          signalCtx.restore();
          signalFrameId = window.requestAnimationFrame(animateSignals);
        };

        const rebuildSignals = () => {
          if (!(signalCanvas instanceof HTMLCanvasElement) || !signalCtx) return;

          // Respect reduced-motion preference — skip animation entirely
          if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

          // Rebuild world size before computing dot count
          sceneWidth  = window.innerWidth;
          worldHeight = Math.max(window.innerHeight, document.documentElement.scrollHeight);
          isLiteMode  = sceneWidth < 768;
          liteFrameInterval = isLiteMode ? 1000 / 30 : 0;

          window.cancelAnimationFrame(signalFrameId);
          signalDots = [];
          resizeSignalCanvas();

          // Scale dot count with page height so density stays consistent while scrolling.
          // Capped at 3x the viewport base so very long pages stay performant.
          const pageRatio = Math.min(worldHeight / sceneHeight, 3);
          const baseDots  =
            sceneWidth >= 1280 ? 50
            : sceneWidth >= 1024 ? 40
            : sceneWidth >= 768  ? 30
            : sceneWidth >= 480  ? 22
            : 16;
          const dotCount = Math.round(baseDots * pageRatio);

          for (let i = 0; i < dotCount; i += 1) {
            signalDots.push(createSignalDot(signalDots));
          }
          signalLastFrame = performance.now();
          signalFrameId   = window.requestAnimationFrame(animateSignals);
        };

        rebuildSignals();
        // Rebuild once more after full page load so worldHeight reflects
        // final layout (fonts, images may shift it from the initial value).
        window.addEventListener('load', rebuildSignals, { once: true });

        window.addEventListener('resize', () => {
          window.clearTimeout(signalResizeTimer);
          signalResizeTimer = window.setTimeout(rebuildSignals, 200);
        });

        if (navLinks.length === 0) {
          return;
        }

        let closeMobileMenu = () => {};

        if (
          headerElement &&
          navToggleButton &&
          navList instanceof HTMLElement
        ) {
          const setMobileMenuOpen = (isOpen: boolean) => {
            navToggleButton.setAttribute('aria-expanded', String(isOpen));
            navToggleButton.setAttribute(
              'aria-label',
              isOpen ? 'Close navigation menu' : 'Open navigation menu',
            );

            if (isOpen) {
              headerElement.setAttribute('data-menu-open', '');
            } else {
              headerElement.removeAttribute('data-menu-open');
            }
          };

          closeMobileMenu = () => {
            setMobileMenuOpen(false);
          };

          navToggleButton.addEventListener('click', () => {
            const isOpen =
              navToggleButton.getAttribute('aria-expanded') === 'true';
            setMobileMenuOpen(!isOpen);
          });

          navLinks.forEach((link) => {
            link.addEventListener('click', () => {
              if (!desktopMediaQuery.matches) {
                closeMobileMenu();
              }
            });
          });

          document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape') {
              closeMobileMenu();
            }
          });

          desktopMediaQuery.addEventListener('change', (event) => {
            if (event.matches) {
              closeMobileMenu();
            }
          });

          closeMobileMenu();
        }

        const sections = navLinks
          .map((link) => {
            const href = link.getAttribute('href');

            if (!href || !href.startsWith('#')) {
              return null;
            }

            return document.querySelector(href);
          })
          .filter(
            (section): section is HTMLElement => section instanceof HTMLElement,
          );

        if (sections.length === 0) {
          return;
        }

        const sectionIds = new Set(sections.map((section) => section.id));
        let activeSectionId = '';

        const getHeaderOffset = () =>
          headerElement ? headerElement.getBoundingClientRect().height : 64;

        const setActiveLink = (sectionId: string) => {
          if (!sectionId || sectionId === activeSectionId) {
            return;
          }

          activeSectionId = sectionId;

          navLinks.forEach((link) => {
            const href = link.getAttribute('href');
            const isActive = href === `#${sectionId}`;

            link.classList.toggle('is-active', isActive);

            if (isActive) {
              link.setAttribute('aria-current', 'true');
            } else {
              link.removeAttribute('aria-current');
            }
          });
        };

        const hashSectionId = () => window.location.hash.replace('#', '');

        navLinks.forEach((link) => {
          link.addEventListener('click', () => {
            const targetId = (link.getAttribute('href') ?? '').replace('#', '');

            if (!sectionIds.has(targetId)) {
              return;
            }

            setActiveLink(targetId);
          });
        });

        const syncHeaderScrolledState = () => {
          if (!headerElement) {
            return;
          }

          if (window.scrollY > 8) {
            headerElement.setAttribute('data-scrolled', '');
          } else {
            headerElement.removeAttribute('data-scrolled');
          }
        };

        const syncActiveFromScroll = () => {
          const headerOffset = getHeaderOffset();
          const nearPageBottom =
            window.innerHeight + window.scrollY >=
            document.documentElement.scrollHeight - 2;
          const hashId = hashSectionId();

          if (nearPageBottom && sectionIds.has(hashId)) {
            setActiveLink(hashId);
            return;
          }

          const referenceLine =
            headerOffset + (window.innerHeight - headerOffset) * 0.35;

          const sectionAtReferenceLine = sections.find((section) => {
            const bounds = section.getBoundingClientRect();

            return (
              bounds.top <= referenceLine && bounds.bottom > referenceLine
            );
          });

          if (sectionAtReferenceLine) {
            setActiveLink(sectionAtReferenceLine.id);
            return;
          }

          let currentSection = sections[0];

          for (const section of sections) {
            if (section.getBoundingClientRect().top <= referenceLine) {
              currentSection = section;
            } else {
              break;
            }
          }

          setActiveLink(currentSection.id);
        };

        const syncActiveFromHash = () => {
          const sectionId = hashSectionId();

          if (sectionIds.has(sectionId)) {
            setActiveLink(sectionId);
            window.requestAnimationFrame(syncActiveFromScroll);
            return;
          }

          syncActiveFromScroll();
        };

        let isScrollSyncScheduled = false;

        const syncOnScroll = () => {
          if (isScrollSyncScheduled) {
            return;
          }

          isScrollSyncScheduled = true;

          window.requestAnimationFrame(() => {
            syncHeaderScrolledState();
            syncActiveFromScroll();
            isScrollSyncScheduled = false;
          });
        };

        syncHeaderScrolledState();
        syncActiveFromHash();

        window.addEventListener('hashchange', () => {
          if (!desktopMediaQuery.matches) {
            closeMobileMenu();
          }

          syncActiveFromHash();
        });

        window.addEventListener('resize', () => {
          window.requestAnimationFrame(syncActiveFromScroll);
        });

        window.addEventListener('scroll', syncOnScroll, {
          passive: true,
        });
      })();
    </script>
  </body>
</html>
