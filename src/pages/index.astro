---
import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';

const monthLabels = [
  'Jan',
  'Feb',
  'Mar',
  'Apr',
  'May',
  'Jun',
  'Jul',
  'Aug',
  'Sep',
  'Oct',
  'Nov',
  'Dec',
] as const;

const toNormalizedProjectDate = (value: string) => {
  const isoDateMatch = value.match(/^(\d{4})-(0[1-9]|1[0-2])$/);

  if (isoDateMatch) {
    const [, year, month] = isoDateMatch;

    return {
      sortKey: `${year}-${month}`,
      label: `${monthLabels[Number(month) - 1]} ${year}`,
    };
  }

  const labelDateMatch = value.match(
    /^(Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec) (\d{4})$/,
  );

  if (labelDateMatch) {
    const [, monthLabel, year] = labelDateMatch;
    const monthIndex =
      monthLabels.indexOf(monthLabel as (typeof monthLabels)[number]) + 1;

    return {
      sortKey: `${year}-${String(monthIndex).padStart(2, '0')}`,
      label: `${monthLabel} ${year}`,
    };
  }

  return { sortKey: '0000-00', label: value };
};

const normalizeMarkdownExcerpt = (value: string) =>
  value
    .replace(/```[\s\S]*?```/g, ' ')
    .replace(/`([^`]+)`/g, '$1')
    .replace(/!\[[^\]]*\]\([^)]*\)/g, ' ')
    .replace(/\[([^\]]+)\]\([^)]*\)/g, '$1')
    .replace(/^\s*[-*+]\s+/gm, '')
    .replace(/^\s*\d+\.\s+/gm, '')
    .replace(/\n+/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();

const escapeRegExp = (value: string) =>
  value.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');

const extractNarrativeSection = (body: string, heading: string) => {
  const sectionPattern = new RegExp(
    `^##\\s+${escapeRegExp(heading)}\\s*$([\\s\\S]*?)(?=^##\\s+\\w[\\w\\s-]*\\s*$|(?![\\s\\S]))`,
    'im',
  );

  const sectionMatch = body.match(sectionPattern);

  return sectionMatch ? normalizeMarkdownExcerpt(sectionMatch[1]) : '';
};

const toProjectNarrative = (
  body: string,
  summary: string,
  impact: string[],
) => ({
  problem: extractNarrativeSection(body, 'Problem') || summary,
  approach:
    extractNarrativeSection(body, 'Approach') ||
    'Implemented with a reliability-first cloud architecture and automation focus.',
  result: extractNarrativeSection(body, 'Result') || impact[0] || summary,
});

const projects = (await getCollection('projects'))
  .map((project) => ({
    ...project,
    narrative: toProjectNarrative(
      project.body ?? '',
      project.data.summary,
      project.data.impact,
    ),
  }))
  .sort((a, b) =>
    toNormalizedProjectDate(b.data.startDate).sortKey.localeCompare(
      toNormalizedProjectDate(a.data.startDate).sortKey,
    ),
  );

const toStackFilterValue = (value: string) =>
  value
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '');

const stackOptions = Array.from(
  new Set(projects.flatMap((project) => project.data.stack)),
).sort((a, b) => a.localeCompare(b));

const laneLabel = (lane: 'professional' | 'personal') =>
  lane.charAt(0).toUpperCase() + lane.slice(1);

const dateRange = (startDate: string, endDate: string) => {
  const start = toNormalizedProjectDate(startDate).label;
  const end =
    endDate.toLowerCase() === 'present'
      ? 'Present'
      : toNormalizedProjectDate(endDate).label;

  return `${start} — ${end}`;
};

