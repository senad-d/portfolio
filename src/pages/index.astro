      const filterTrigger = document.querySelector('[data-filter-trigger]');
      const filterMenu = document.querySelector('[data-filter-menu]');
      const filterSummaryLabel = document.querySelector(
        '[data-filter-summary-label]',
      );

      const laneOptionInputs = Array.from(
        document.querySelectorAll('[data-lane-option]'),
      ).filter(
        (input): input is HTMLInputElement =>
          input instanceof HTMLInputElement && input.type === 'radio',
      );

      const stackOptionInputs = Array.from(
        document.querySelectorAll('[data-stack-option]'),
      ).filter(
        (input): input is HTMLInputElement =>
          input instanceof HTMLInputElement && input.type === 'checkbox',
      );

      const stackClearButton = document.querySelector('[data-stack-clear]');

      const projectItems = Array.from(
        document.querySelectorAll('[data-project-item]'),
      ).filter((item): item is HTMLElement => item instanceof HTMLElement);

      const projectDetailPanels = projectItems
        .map((item) => item.querySelector('[data-project-details]'))
        .filter(
          (panel): panel is HTMLDetailsElement =>
            panel instanceof HTMLDetailsElement,
        );

      const emptyState = document.querySelector('[data-project-empty]');
      const filterStatus = document.querySelector('[data-filter-status]');

      if (projectItems.length === 0) {
        return;
      }

      const selectedStacks = new Set<string>();
      let activeLaneFilter = 'all';
      let isFilterMenuOpen = false;

      const laneFilterLabels: Record<string, string> = {
        all: 'All lanes',
        professional: 'Professional',
        personal: 'Personal',
      };

      const prefersReducedMotion = window.matchMedia(
        '(prefers-reduced-motion: reduce)',
      ).matches;

      const panelAnimations = new WeakMap<HTMLDetailsElement, Animation>();

      const getPanelContent = (panel: HTMLDetailsElement) => {
        const content = panel.querySelector('.details-content');

        return content instanceof HTMLElement ? content : null;
      };

      const clearPanelInlineStyles = (content: HTMLElement) => {
        content.style.overflow = '';
        content.style.height = '';
        content.style.opacity = '';
      };

      const stopPanelAnimation = (panel: HTMLDetailsElement) => {
        const animation = panelAnimations.get(panel);

        if (!animation) {
          return;
        }

        panelAnimations.delete(panel);
        animation.cancel();
      };

      const expandPanel = (
        panel: HTMLDetailsElement,
        options: { animate?: boolean } = {},
      ) => {
        const content = getPanelContent(panel);

        stopPanelAnimation(panel);
        panel.open = true;

        if (!content) {
          return;
        }

        if (options.animate === false || prefersReducedMotion) {
          clearPanelInlineStyles(content);
          return;
        }

        const targetHeight = content.scrollHeight;

        if (targetHeight <= 0) {
          clearPanelInlineStyles(content);
          return;
        }

        content.style.overflow = 'hidden';

        const animation = content.animate(
          [
            {
              height: '0px',
              opacity: 0,
            },
            {
              height: `${targetHeight}px`,
              opacity: 1,
            },
          ],
          {
            duration: 170,
            easing: 'cubic-bezier(0.22, 1, 0.36, 1)',
            fill: 'forwards',
          },
        );

        panelAnimations.set(panel, animation);

        const cleanup = () => {
          if (panelAnimations.get(panel) !== animation) {
            return;
          }

          panelAnimations.delete(panel);
          clearPanelInlineStyles(content);
        };

        animation.addEventListener('finish', cleanup, { once: true });
        animation.addEventListener('cancel', cleanup, { once: true });
      };

      const collapsePanel = (
        panel: HTMLDetailsElement,
        options: { animate?: boolean } = {},
      ) => {
        const content = getPanelContent(panel);

        stopPanelAnimation(panel);

        if (!panel.open) {
          if (content) {
            clearPanelInlineStyles(content);
          }

          return;
        }

        if (!content) {
          panel.open = false;
          return;
        }

        if (options.animate === false || prefersReducedMotion) {
          panel.open = false;
          clearPanelInlineStyles(content);
          return;
        }

        const startHeight = content.offsetHeight || content.scrollHeight;

        if (startHeight <= 0) {
          panel.open = false;
          clearPanelInlineStyles(content);
          return;
        }

        content.style.overflow = 'hidden';

        const animation = content.animate(
          [
            {
              height: `${startHeight}px`,
              opacity: 1,
            },
            {
              height: '0px',
              opacity: 0,
            },
          ],
          {
            duration: 140,
            easing: 'cubic-bezier(0.4, 0, 1, 1)',
            fill: 'forwards',
          },
        );

        panelAnimations.set(panel, animation);

        const finalize = () => {
          if (panelAnimations.get(panel) !== animation) {
            return;
          }

          panelAnimations.delete(panel);
          panel.open = false;
          clearPanelInlineStyles(content);
        };

        animation.addEventListener('finish', finalize, { once: true });
        animation.addEventListener('cancel', finalize, { once: true });
      };

      const syncExpandedCardState = () => {
        projectItems.forEach((item) => {
          const panel = item.querySelector('[data-project-details]');
          const isExpanded = panel instanceof HTMLDetailsElement && panel.open;

          item.classList.toggle('is-expanded', isExpanded);
        });
      };

      const syncFilterSummaryLabel = () => {
        if (!(filterSummaryLabel instanceof HTMLElement)) {
          return;
        }

        const laneLabel = laneFilterLabels[activeLaneFilter] ?? 'All lanes';

        let stackLabel = 'Any stack';

        if (selectedStacks.size === 1) {
          const selectedInput = stackOptionInputs.find(
            (input) => input.checked,
          );
          stackLabel = selectedInput?.dataset.stackLabel ?? '1 stack selected';
        } else if (selectedStacks.size > 1) {
          stackLabel = `${selectedStacks.size} stacks selected`;
        }

        filterSummaryLabel.textContent = `${laneLabel} · ${stackLabel}`;
      };

      const applyFilters = () => {
        let visibleCount = 0;

        projectItems.forEach((item) => {
          const lane = item.dataset.projectLane;
          const projectStacks = (item.dataset.projectStacks ?? '')
            .split('|')
            .filter((value) => value.length > 0);

          const isLaneMatch =
            activeLaneFilter === 'all' || lane === activeLaneFilter;
          const isStackMatch =
            selectedStacks.size === 0 ||
            projectStacks.some((stack) => selectedStacks.has(stack));
          const isVisible = isLaneMatch && isStackMatch;
          const detailsPanel = item.querySelector('[data-project-details]');

          item.hidden = !isVisible;
          item.setAttribute('aria-hidden', String(!isVisible));

          if (!isVisible) {
            item.classList.remove('is-expanded');

            if (detailsPanel instanceof HTMLDetailsElement) {
              collapsePanel(detailsPanel, { animate: false });
            }

            return;
          }

          visibleCount += 1;
        });

        if (emptyState instanceof HTMLElement) {
          emptyState.hidden = visibleCount > 0;
        }

        syncFilterSummaryLabel();

        if (filterStatus instanceof HTMLElement) {
          const laneScope =
            activeLaneFilter === 'all'
              ? ''
              : ` ${activeLaneFilter.toLowerCase()}`;
          const stackScope =
            selectedStacks.size === 0
              ? ''
              : ` matching ${selectedStacks.size} stack option${selectedStacks.size === 1 ? '' : 's'}`;

          filterStatus.textContent = `Showing ${visibleCount}${laneScope} project${visibleCount === 1 ? '' : 's'}${stackScope}.`;
        }

        syncExpandedCardState();
      };

      const closeFilterMenu = (options: { focusTrigger?: boolean } = {}) => {
        if (
          !(filterTrigger instanceof HTMLButtonElement) ||
          !(filterMenu instanceof HTMLElement)
        ) {
          return;
        }

        isFilterMenuOpen = false;
        filterMenu.hidden = true;
        filterTrigger.setAttribute('aria-expanded', 'false');

        if (options.focusTrigger) {
          filterTrigger.focus();
        }
      };

      const openFilterMenu = () => {
        if (
          !(filterTrigger instanceof HTMLButtonElement) ||
          !(filterMenu instanceof HTMLElement)
        ) {
          return;
        }

        isFilterMenuOpen = true;
        filterMenu.hidden = false;
        filterTrigger.setAttribute('aria-expanded', 'true');
      };

      projectDetailPanels.forEach((panel) => {
        const summary = panel.querySelector('summary');

        if (!(summary instanceof HTMLElement)) {
          return;
        }

        summary.addEventListener('click', (event) => {
          event.preventDefault();

          if (panel.open) {
            collapsePanel(panel);
            syncExpandedCardState();
            return;
          }

          expandPanel(panel);
          syncExpandedCardState();
        });

        panel.addEventListener('toggle', syncExpandedCardState);
      });

      laneOptionInputs.forEach((input) => {
        input.addEventListener('change', () => {
          if (!input.checked || input.value.length === 0) {
            return;
          }

          activeLaneFilter = input.value;
          applyFilters();
        });
      });

      stackOptionInputs.forEach((input) => {
        input.addEventListener('change', () => {
          if (input.value.length === 0) {
            return;
          }

          if (input.checked) {
            selectedStacks.add(input.value);
          } else {
            selectedStacks.delete(input.value);
          }

          applyFilters();
        });
      });

      if (stackClearButton instanceof HTMLButtonElement) {
        stackClearButton.addEventListener('click', (event) => {
          event.preventDefault();

          selectedStacks.clear();
          stackOptionInputs.forEach((input) => {
            input.checked = false;
          });

          applyFilters();
        });
      }

      if (
        filterContainer instanceof HTMLElement &&
        filterTrigger instanceof HTMLButtonElement &&
        filterMenu instanceof HTMLElement
      ) {
        filterTrigger.addEventListener('click', () => {
          if (isFilterMenuOpen) {
            closeFilterMenu();
            return;
          }

          openFilterMenu();
        });

        document.addEventListener('click', (event) => {
          if (!isFilterMenuOpen) {
            return;
          }

          const target = event.target;

          if (!(target instanceof Node)) {
            return;
          }

          if (!filterContainer.contains(target)) {
            closeFilterMenu();
          }
        });

        document.addEventListener('keydown', (event) => {
          if (event.key !== 'Escape' || !isFilterMenuOpen) {
            return;
          }

          closeFilterMenu({ focusTrigger: true });
        });

        closeFilterMenu();
      }

      const initialLaneFilter =
        laneOptionInputs.find((input) => input.checked) ??
        laneOptionInputs.find((input) => input.value === 'all');

      if (initialLaneFilter) {
        initialLaneFilter.checked = true;
        activeLaneFilter = initialLaneFilter.value;
      }

      stackOptionInputs.forEach((input) => {
        if (input.checked && input.value.length > 0) {
          selectedStacks.add(input.value);
        }
      });

      applyFilters();
    })();
  </script>
</MainLayout>
